     }
     int[] ar=n.stream().mapToInt(Integer::intValue).toArray();
     List<Integer> sec=new ArrayList<>();
     int sum=1;
     for (int i = 0; i < ar.length-1; i++) {
        if (ar[i+1]-ar[i]==1) {
            sum+=1;
        }else{ 
            sec.add(sum);
            sum=1;}   
               }
     sec.add(sum);
     sec.sort((a, b) -> b - a);//decending order of sec
    int ans=sec.get(0);
    return ans;}
