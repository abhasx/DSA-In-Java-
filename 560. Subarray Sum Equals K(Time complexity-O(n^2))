public class Practice {
    public static void main(String[] args) {
           int[] ar={5,6,8,10,12,1,4};
            int k=5;
            Solution s=new Solution();
            s.subarraySum(ar, k);
    }
}class Solution {
    public int subarraySum(int[] nums, int k) {
        int ans=0;
for (int i = 0; i < nums.length; i++) {
    int sum = 0;
    for (int j = i; j < nums.length; j++) {
        sum += nums[j];
        if (sum==k) {
            ans++;
        }
    }
} 
 return ans;}
}
